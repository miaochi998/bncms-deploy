# ============================================================
# BangNiCMS 反向代理配置（PR9）
# 设计文档：docs/deployment/15-module-f-compose.md
# ------------------------------------------------------------
# 域名布局：
#   ${DOMAIN}              → 前台 + API（同源，避免 CORS）
#   admin.${DOMAIN}        → 后台（subdomain）
#
# 证书：Caddy 自动申请 / 续期 Let's Encrypt（TLS-ALPN-01）
# 压缩：gzip + zstd 自动协商
# HTTP/3：ports 443 UDP 已暴露
# ============================================================

# ============================================================
# 主站：前台 + API
# ============================================================
{$DOMAIN} {
	tls {$ADMIN_EMAIL}

	# 静态上传文件（大尺寸媒体，直接走 server 的 /uploads/* 静态路由）
	handle /uploads/* {
		reverse_proxy server:6530
	}

	# API（/api/* 全部路由到 server）
	handle /api/* {
		reverse_proxy server:6530
	}

	# 健康检查（server 未加 API 前缀的 /health 端点）
	handle /health {
		reverse_proxy server:6530
	}

	# 安装向导端点（server 暴露在根路径，不在 /api 前缀下）
	# /install (page) 由 Next.js admin 处理，但 install 客户端会跨域 fetch 到本主域
	handle /install/* {
		reverse_proxy server:6530
	}

	# 前台其他全部走 web
	handle {
		reverse_proxy web:6532
	}

	# 压缩
	encode gzip zstd

	# 安全头
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
		# HSTS（上线 2 周稳定后手动放开）
		# Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	}

	# 访问日志
	log {
		output file /var/log/caddy/main.access.log {
			roll_size 100mb
			roll_keep 10
		}
		format json
	}
}

# ============================================================
# 后台（子域名）
# ============================================================
admin.{$DOMAIN} {
	tls {$ADMIN_EMAIL}

	# 关键：admin 客户端 bundle 用相对路径 fetch /api/*，
	# 这里需要把 /api/* 反向代理到 server，让 admin 跨域调用看起来同域。
	handle /api/* {
		reverse_proxy server:6530
	}

	# 媒体上传文件读取（如富文本编辑器引用 /uploads/xxx）
	handle /uploads/* {
		reverse_proxy server:6530
	}

	# 健康检查
	handle /health {
		reverse_proxy server:6530
	}

	# 安装向导客户端 API（/install/check-env, /install/migrate, /install/status 等）
	# 注：精确路径 /install（无尾部斜杠）由 admin 渲染向导页面，故不会被这条规则吞掉。
	# 若客户端请求 /install/check-env 等子路径，由 server 处理。
	handle /install/* {
		reverse_proxy server:6530
	}

	# 其他所有请求走 admin 容器（Next.js standalone 监听 6534）
	handle {
		reverse_proxy admin:6534
	}

	# 压缩
	encode gzip zstd

	# 安全头（admin 需要更严格）
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy same-origin
		# 防 CSRF：后台 cookie 在 server 端已设置 SameSite=Lax
	}

	# 大文件上传支持（媒体库 POST 会转发到 server，走主站 /api，
	# 此处无需调 max_size —— admin 页面自身无上传端点）

	# 访问日志
	log {
		output file /var/log/caddy/admin.access.log {
			roll_size 100mb
			roll_keep 10
		}
		format json
	}
}
